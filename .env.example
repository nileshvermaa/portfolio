# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.

# ── Contact form (Web3Forms) ─────────────────────────────────────────
# Get a free access key at https://web3forms.com
# Without this, the contact form runs in demo/simulation mode.
VITE_WEB3FORMS_KEY=your_web3forms_access_key_here

# ── Analytics (Plausible / Umami) ───────────────────────────────────
# Optional — privacy-friendly analytics
# VITE_PLAUSIBLE_DOMAIN=nilesh.sys
# VITE_UMAMI_WEBSITE_ID=your-umami-website-id

# ── Deploy ───────────────────────────────────────────────────────────
# Set in Vercel dashboard, not needed locally
# VERCEL_URL is injected automatically by Vercel
